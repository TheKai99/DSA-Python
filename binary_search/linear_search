# Cards = [13,11,10,7,4,3,1,0]
# query = 7
# output = 3

import jovian

def load_cards(cards,query):

    position = 0
    while True:
     if cards[position] == query:
         return position
     position+=1

     if position == len(cards):
      return -1 

print(load_cards([13,11,10,7,4,3,1,0],7))

